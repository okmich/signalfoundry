{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "okmich_quant_core/logging/schema/circuit_breaker_tripped.json",
  "title": "LOGGING_CONTRACT circuit_breaker_tripped record (v1.0.0)",
  "description": "Breaker trip (LOGGING_CONTRACT §7.3). Per-strategy; the ops-channel record emitted in addition to the existing Telegram/critical alert so ops can see why a symbol went quiet.",
  "type": "object",
  "properties": {
    "log_schema_version": {"type": "string"},
    "event": {"const": "circuit_breaker_tripped"},
    "wall_clock_utc": {"type": "string", "format": "date-time"},
    "runner_id": {"type": "string"},
    "runner_start_token": {"type": "string"},
    "logical_system_id": {"type": "string"},
    "strategy": {"type": "string"},
    "symbol": {"type": "string"},
    "timeframe": {"type": "integer"},
    "broker": {"type": "string"},
    "account_id": {"type": "string"},
    "broker_session_id": {"type": ["string", "null"]},
    "order_tag": {"type": ["string", "integer", "null"]},
    "consecutive_errors": {"type": "integer"},
    "last_error": {"type": ["string", "null"]}
  },
  "required": [
    "log_schema_version", "event", "wall_clock_utc", "runner_id", "runner_start_token",
    "logical_system_id", "strategy", "symbol", "timeframe", "broker", "account_id",
    "consecutive_errors"
  ],
  "additionalProperties": true
}
